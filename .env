# Agent数据平台环境变量配置
# 优化后的配置 - 强化代码执行和Web功能

# ============================================================================
# LLM API 配置
# ============================================================================

# 1. Google Gemini API 配置 (推荐)
# 获取API密钥: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSyDbiXNxcSvPEK2UnObGjHFkY3g3xuA-lTs
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash-preview-05-20 # 使用更稳定且常用的模型
GEMINI_MAX_TOKENS=4096      # 增加最大输出Token数
GEMINI_TEMPERATURE=0.1      # 设置较低的温度以获得更确定的输出

# 2. DeepSeek API 配置 (备选)
# 获取API密钥: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_API_URL=https://api.deepseek.com/v1

# 3. OpenAI API 配置 (备选)
# 获取API密钥: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_API_BASE=https://api.openai.com/v1

# 本地vLLM服务URL (最后备选)
VLLM_URL=http://localhost:8000

# ============================================================================
# 运行时配置 (解决缓存过度依赖问题)
# ============================================================================

# 禁用缓存 - 强制代码任务使用LLM生成新代码，避免过度依赖缓存
DISABLE_CACHE=true

# 保存单独的轨迹文件 (可选)
SAVE_INDIVIDUAL_TRAJECTORIES=false

# ============================================================================
# 系统配置
# ============================================================================

# Redis连接URL
REDIS_URL=redis://localhost:6379

# 日志级别
LOG_LEVEL=INFO

# 并发控制
MAX_CONCURRENT=4

# ============================================================================
# 沙盒配置
# ============================================================================

# 允许自动安装的Python包 (逗号分隔)
SANDBOX_ALLOWED_PACKAGES=numpy,pandas,matplotlib,scipy,sympy,scikit-learn,requests,beautifulsoup4,lxml,markdownify

# ============================================================================
# 服务配置
# ============================================================================

# 主服务端口
PORT=8080

# Metrics端口配置
METRICS_PORT_SANDBOX=8001
METRICS_PORT_WEB=8002
METRICS_PORT_REASONING=8003

# Synthesis服务配置
SYNTHESIS_ENABLED=true
SYNTHESIS_DB=/app/output/synthesis.db
